# Database (defaults to local SQLite for dev; use postgres for docker-compose)
DATABASE_URL=sqlite:///./dev.db
# DATABASE_URL=postgresql+psycopg2://kheritage:kheritage@db:5432/kheritage

# JWT
JWT_SECRET_KEY=change-me-in-production-use-32-bytes-of-random
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ALGORITHM=HS256

# Service mode: "mock" (default, no external keys required) or "live"
LLM_PROVIDER=mock
HERITAGE_PROVIDER=mock
# When HERITAGE_PROVIDER=live, this selects the open-API source:
#   jangseogak    ŌĆö ņ×źņä£Ļ░ü Digital Archive (PR #33, default)
#   koreanstudies ŌĆö ĒĢ£ĻĄŁĒĢÖņ×ÉļŻīĒÅ¼ĒäĖ (kostma.aks.ac.kr, PR #35)
#   nlk           ŌĆö ĻĄŁļ”ĮņżæņĢÖļÅäņä£Ļ┤Ć (nl.go.kr) ŌĆö requires NLK_API_KEY,
#                   otherwise the factory transparently keeps the mock matcher
#   gihohak       ŌĆö ĻĖ░ĒśĖņ£ĀĒĢÖ Ļ│Āļ¼ĖĒŚī ĒåĄĒĢ®ņĀĢļ│┤ņŗ£ņŖżĒģ£ (giho.cnu.ac.kr,
#                   ņČ®ļé©ļīĆ) ŌĆö fully open, no key required
#   multi         ŌĆö MultiSourceHeritageAdapter fan-in across the sources
#                   listed in HERITAGE_MULTI_SOURCES. Per-source failures
#                   are isolated; cross-source dupes are collapsed by
#                   title.
HERITAGE_LIVE_SOURCE=jangseogak
# Comma-separated list of sources used when HERITAGE_LIVE_SOURCE=multi.
# Allowed values: jangseogak, koreanstudies, nlk, gihohak. Unknown names
# and unauthenticated sources (e.g. nlk without NLK_API_KEY) are silently
# skipped at boot. NLK is omitted from the default so the multi pipeline
# boots without a key; add it once NLK_API_KEY is provisioned.
HERITAGE_MULTI_SOURCES=jangseogak,koreanstudies,gihohak
PAYMENTS_PROVIDER=mock
TRENDS_PROVIDER=mock

# Optional live-mode keys (only used when *_PROVIDER=live)
# Gemini key ŌĆö used by both the live LLM adapter (LLM_PROVIDER=live, spec ┬¦6.1/┬¦6.2)
# and the trend-LLM expansion provider (TRENDS_OPEN_LLM_ENABLED=true). When unset
# the factory transparently degrades to the mock adapter.
GEMINI_API_KEY=
# Gemini live LLM tuning (spec ┬¦6.1 / ┬¦6.2 defaults baked in ŌĆö override only
# for staging mirrors or alternate models like gemini-2.5-flash).
GEMINI_MODEL=gemini-2.5-pro
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_REQUEST_TIMEOUT_SECONDS=30.0
GEMINI_RECIPE_MAX_TOKENS=4000
GEMINI_TRANSLATE_MAX_TOKENS=2000
GEMINI_RECIPE_TEMPERATURE=0.7
GEMINI_TRANSLATE_TEMPERATURE=0.1
# ņ×źņä£Ļ░ü Digital Archive Open API is *fully open* (no key required, no header
# auth). The key field stays for forward-compatibility; the live endpoint is
# overridable via JANGSEOGAK_BASE_URL (e.g. for staging / internal mirror).
JANGSEOGAK_API_KEY=
JANGSEOGAK_BASE_URL=https://jsg.aks.ac.kr/api
# ĒĢ£ĻĄŁĒĢÖņ×ÉļŻīĒÅ¼ĒäĖ (ĒĢ£ĻĄŁĒĢÖņżæņĢÖņŚ░ĻĄ¼ņøÉ) Open API is also fully open
# (no key required). The key field stays for forward-compatibility; override
# the base URL via KOREANSTUDIES_BASE_URL for staging/mirror endpoints.
KOREANSTUDIES_API_KEY=
KOREANSTUDIES_BASE_URL=https://kostma.aks.ac.kr
# ĻĄŁļ”ĮņżæņĢÖļÅäņä£Ļ┤Ć (NLK) Open API REQUIRES an API key. Apply at
# https://www.nl.go.kr/NL/contents/N31101030500.do (admin approval, 1ŌĆō2 business
# days). Without NLK_API_KEY the factory keeps the mock matcher even when
# HERITAGE_LIVE_SOURCE=nlk, so recipe-generate stays available either way.
NLK_API_KEY=
NLK_BASE_URL=https://www.nl.go.kr
# ĻĖ░ĒśĖņ£ĀĒĢÖ Ļ│Āļ¼ĖĒŚī ĒåĄĒĢ®ņĀĢļ│┤ņŗ£ņŖżĒģ£ (ņČ®ļé©ļīĆ) Open API is fully open
# (no key required). The endpoint defaults to HTTP because the upstream TLS
# chain has historically been incomplete; override to HTTPS if CNU rolls out
# a valid cert. Override the base URL for staging/mirror endpoints.
GIHOHAK_BASE_URL=http://giho.cnu.ac.kr
NFM_API_KEY=
CULTURE_API_KEY=
TOSS_SECRET_KEY=
TOSS_CLIENT_KEY=

# -----------------------------------------------------------------------------
# Heritage retrieval mode + vector-search backends
# -----------------------------------------------------------------------------
# Recipe-generate uses ``HERITAGE_RETRIEVAL_MODE`` to pick how it grounds
# the LLM prompt on archival documents:
#   keyword (default) ŌĆö call the keyword heritage adapter only (byte-identical
#                       to pre-hybrid behaviour).
#   hybrid            ŌĆö blend keyword + semantic results via
#                       ``HybridHeritageAdapter`` (PR #41).
HERITAGE_RETRIEVAL_MODE=keyword
# ``EMBEDDING_PROVIDER`` selects the textŌåÆvector backend used by both the
# indexer and the hybrid retrieval path:
#   mock    (default) ŌĆö deterministic hash vectors, no network I/O.
#   gemini            ŌĆö Google AI Studio ``text-embedding-004`` (free tier,
#                       reuses ``GEMINI_API_KEY`` ŌĆö no new credentials).
#   live              ŌĆö Vertex AI ``text-embedding-005`` (paid; needs
#                       ``VERTEX_PROJECT_ID`` + ``GOOGLE_OAUTH_ACCESS_TOKEN``).
EMBEDDING_PROVIDER=mock
# ``VECTOR_SEARCH_PROVIDER`` selects the vector-store backend:
#   mock     (default) ŌĆö in-memory cosine, namespace-isolated dict (tests).
#   pgvector           ŌĆö Postgres-backed (no new infra; pair with
#                        ``EMBEDDING_PROVIDER=gemini`` for the free
#                        zero-cost hybrid retrieval stack).
#   live               ŌĆö Vertex AI Vector Search (paid; needs the
#                        ``VERTEX_VECTOR_INDEX_*`` env vars per source).
VECTOR_SEARCH_PROVIDER=mock
# ``PGVECTOR_NATIVE_KNN`` toggles the pgvector adapter's
# ``ORDER BY embedding <=> :v`` fast path (HNSW index on
# ``vector_search_datapoints.embedding``). Defaults to ``true`` ŌĆö the
# adapter probes the connected DB for the extension + column at runtime
# and silently falls back to Python brute-force when either is missing
# (e.g. SQLite tests, Postgres deployments that haven't run
# ``alembic upgrade head``). Set to ``false`` to force the brute-force
# path for A/B benchmarking or recall-regression isolation.
PGVECTOR_NATIVE_KNN=true
# Vertex AI configuration (only used when ``EMBEDDING_PROVIDER=live`` or
# ``VECTOR_SEARCH_PROVIDER=live``). Missing values transparently degrade
# to the mock adapter at boot ŌĆö recipe-generate stays available.
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
VERTEX_EMBEDDING_MODEL=text-embedding-005
VERTEX_EMBEDDING_DIMENSION=768
VERTEX_VECTOR_NAMESPACES=jangseogak,koreanstudies,nlk,gihohak,nihc
# OAuth access token for Vertex AI REST calls. Local dev / CI: paste a
# freshly minted token from ``gcloud auth print-access-token``. Production:
# replace by passing a metadata-server-backed ``token_provider`` callable
# to the Vertex adapters instead of relying on this env var.
GOOGLE_OAUTH_ACCESS_TOKEN=
# Per-namespace Vertex AI Vector Search resource ids. Required when
# ``VECTOR_SEARCH_PROVIDER=live`` ŌĆö namespaces missing any of the four
# values are silently skipped at boot with a warning. Substitute the
# namespace name (uppercased) for ``<NAMESPACE>`` below:
#   VERTEX_VECTOR_INDEX_ID_<NAMESPACE>            # bare index resource id
#   VERTEX_VECTOR_DEPLOYED_INDEX_ID_<NAMESPACE>   # deployedIndexId on endpoint
#   VERTEX_VECTOR_INDEX_ENDPOINT_ID_<NAMESPACE>   # IndexEndpoint resource id
#   VERTEX_VECTOR_INDEX_ENDPOINT_HOST_<NAMESPACE> # per-endpoint public domain

# Heritage corpus ŌåÆ vector index backfill. Required first-time step
# after switching to ``HERITAGE_RETRIEVAL_MODE=hybrid`` so the semantic
# side has documents to retrieve. Drive via either:
#   python -m app.jobs.backfill_heritage_index
#   POST /v1/admin/heritage/index/backfill   (admin-only, blocking)
# Comma-separated; empty falls back to the curated DEFAULT_BACKFILL_QUERIES
# pool (Korean food / ritual terms) baked into ``app.services.vector_search.backfill``.
HERITAGE_BACKFILL_QUERIES=
# Per-query result limit handed to ``HeritageAdapter.search``.
HERITAGE_BACKFILL_PER_QUERY_LIMIT=50
# Docs per ``HeritageIndexer.index_documents`` call. Gemini's free-tier
# batch endpoint caps at 100 inputs/request; 50 keeps headroom.
HERITAGE_BACKFILL_BATCH_SIZE=50

# -----------------------------------------------------------------------------
# Trend discovery pipeline (PR #11ŌĆō#18)
# -----------------------------------------------------------------------------
# Discovery mode controls which `TrendKeywordDiscovery` runs when the daily
# refresh job (or admin `/v1/admin/trends/refresh`) is triggered:
#
#   curated           ŌĆö top-N from the static DEFAULT_WATCHLIST only.
#                       Safe default for dev & CI; no external API calls.
#   shopping_insight  ŌĆö Naver DataLab Shopping Insight food category top-N.
#                       Single source; production e-commerce signal.
#   open              ŌĆö Multi-source fan-in (static + Google Trends RSS +
#                       Naver News + optional Gemini LLM). Recommended for
#                       production.
TRENDS_DISCOVERY_SOURCE=curated

# Production recommendation when going live with `open`:
# TRENDS_DISCOVERY_SOURCE=open
# TRENDS_PROVIDER=live
# NAVER_DATALAB_CLIENT_ID=
# NAVER_DATALAB_CLIENT_SECRET=
# TRENDS_OPEN_LLM_ENABLED=true
# GEMINI_API_KEY=

# Naver DataLab (search-trends adapter + shopping-insight discovery + news source)
NAVER_DATALAB_CLIENT_ID=
NAVER_DATALAB_CLIENT_SECRET=
# Default shopping category is "food" (50000006); see Naver DataLab docs for codes.
NAVER_SHOPPING_INSIGHT_CATEGORY_CODE=50000006

# Open-mode provider toggles (only used when TRENDS_DISCOVERY_SOURCE=open)
TRENDS_OPEN_GOOGLE_ENABLED=true
GOOGLE_TRENDS_GEO=KR
GOOGLE_TRENDS_HL=ko-KR

TRENDS_OPEN_NAVER_NEWS_ENABLED=true
NAVER_NEWS_SEED_QUERIES=ļööņĀĆĒŖĖ ņŗĀņāü,K-ļööņĀĆĒŖĖ,ņŗĀļ®öļē┤ ņ╣┤ĒÄś,ĒŖĖļĀīļō£ ņØīļŻī,ĒĢ£ņŗØ ļööņĀĆĒŖĖ
NAVER_NEWS_DISPLAY_PER_QUERY=50
# A token must appear in this many distinct articles to be kept (df cutoff).
# Higher = stricter; 2 is conservative, 3-4 is appropriate for production.
NAVER_NEWS_MIN_ARTICLE_COUNT=2

# Gemini LLM expansion ŌĆö off by default because it incurs API cost per refresh.
TRENDS_OPEN_LLM_ENABLED=false
GEMINI_TRENDS_MODEL=gemini-2.5-flash
GEMINI_TRENDS_TARGET_COUNT=30

# Daily refresh scheduler (only used by `python -m app.jobs.refresh_scheduler`).
# Default 18 UTC = 03:00 KST so the top-N is ready by morning in Korea.
TRENDS_REFRESH_HOUR_UTC=18

# CORS
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000
